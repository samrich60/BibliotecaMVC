@{
    ViewData["Title"] = "Sobre";
}

<section class="bg-dark text-white py-5">
    <div class="container text-center py-3">
        <i class="bi bi-info-circle display-2 mb-3"></i>
        <h1 class="display-5 fw-bold">Sobre a Biblioteca</h1>
        <p class="lead">Conheça nossa história e missão</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-md-6">
                <h2>Nossa História</h2>
                <p>A Biblioteca Municipal foi fundada em 1985 com o objetivo de democratizar o acesso ao conhecimento para toda a comunidade. Ao longo de quase quatro décadas, crescemos e nos modernizamos mantendo sempre o compromisso com a educação e a cultura.</p>
                <p>Hoje contamos com um acervo de mais de 15.000 títulos, salas de estudo, acesso à internet e programas educacionais para todas as idades.</p>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow p-4 bg-light">
                    <h4 class="mb-3"><i class="bi bi-bullseye text-primary me-2"></i>Nossa Missão</h4>
                    <p>Promover o acesso livre à informação, incentivar a leitura e contribuir para o desenvolvimento cultural e educacional da nossa comunidade.</p>
                    <h4 class="mb-3 mt-3"><i class="bi bi-eye text-success me-2"></i>Nossa Visão</h4>
                    <p>Ser referência regional em cultura, leitura e inclusão digital, atendendo cada vez mais pessoas com qualidade e inovação.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="bg-light py-5">
    <div class="container text-center">
        <h2 class="mb-4">Números que nos orgulham</h2>
        <div class="row g-4">
            <div class="col-md-3">
                <h2 class="text-primary fw-bold">15.000+</h2>
                <p>Títulos no acervo</p>
            </div>
            <div class="col-md-3">
                <h2 class="text-success fw-bold">38 anos</h2>
                <p>De história</p>
            </div>
            <div class="col-md-3">
                <h2 class="text-warning fw-bold">5.000+</h2>
                <p>Usuários cadastrados</p>
            </div>
            <div class="col-md-3">
                <h2 class="text-danger fw-bold">120+</h2>
                <p>Eventos por ano</p>
            </div>
        </div>
    </div>
</section>