@model List<BibliotecaMVC.Models.Livro>

@{
    ViewData["Title"] = "Acervo";
    var categorias = ViewBag.Categorias as List<string> ?? new List<string>();
}

<!-- HERO -->
<section class="bg-dark text-white py-5">
    <div class="container text-center py-3">
        <i class="bi bi-journals display-2 mb-3"></i>
        <h1 class="display-5 fw-bold">Nosso Acervo</h1>
        <p class="lead">Explore nossa coleção de livros disponíveis para empréstimo</p>
    </div>
</section>

<!-- BARRA DE BUSCA -->
<section class="py-4 bg-light">
    <div class="container">
        <form method="get" asp-action="Acervo">
            <div class="row justify-content-center g-2">
                <div class="col-md-7">
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" name="busca" class="form-control"
                               placeholder="Buscar por título, autor ou categoria..."
                               value="@ViewBag.Busca" />
                        <button class="btn btn-dark" type="submit">Buscar</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

<!-- CATEGORIAS -->
<section class="py-3">
    <div class="container">
        <h5 class="mb-3">Filtrar por categoria:</h5>
        <div class="d-flex flex-wrap gap-2">
            <a href="@Url.Action("Acervo")"
               class="btn btn-sm @(string.IsNullOrEmpty(ViewBag.Categoria as string) ? "btn-dark" : "btn-outline-dark")">
                Todos
            </a>
            @foreach (var cat in categorias)
            {
                <a href="@Url.Action("Acervo", new { categoria = cat })"
                   class="btn btn-sm @(ViewBag.Categoria == cat ? "btn-dark" : "btn-outline-dark")">
                    @cat
                </a>
            }
        </div>
    </div>
</section>

<!-- LISTAGEM -->
<section class="pb-5">
    <div class="container">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-search display-1 text-muted"></i>
                <h4 class="mt-3 text-muted">Nenhum livro encontrado</h4>
                <a asp-action="Acervo" class="btn btn-dark mt-3">Ver todos os livros</a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var livro in Model)
                {
                    <div class="col-md-4">
                        <div class="card h-100 shadow-sm">
                            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                                <span class="badge bg-secondary">@livro.Categoria</span>
                                @if (livro.Disponivel)
                                {
                                    <span class="badge bg-success">Disponível</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Emprestado</span>
                                }
                            </div>
                            <div class="card-body">
                                <h5 class="card-title">@livro.Titulo</h5>
                                <p class="text-muted mb-1">
                                    <i class="bi bi-person me-1"></i>@livro.Autor
                                </p>
                                <p class="text-muted mb-2">
                                    <i class="bi bi-calendar me-1"></i>@livro.AnoPublicacao
                                </p>
                                <p class="card-text small">@livro.Descricao</p>
                            </div>
                            <div class="card-footer bg-white">
                                <small class="text-muted">ISBN: @livro.ISBN</small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>