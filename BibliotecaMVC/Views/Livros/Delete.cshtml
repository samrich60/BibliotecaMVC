@model BibliotecaMVC.Models.Livro

@{
    ViewData["Title"] = "Excluir Livro";
}

<div class="bg-danger text-white py-4">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-0"><i class="bi bi-trash me-2"></i>Excluir Livro</h2>
            <small>Esta ação não pode ser desfeita!</small>
        </div>
        <a asp-action="Index" class="btn btn-outline-light btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Voltar
        </a>
    </div>
</div>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow-sm">
                <div class="card-header bg-danger text-white">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Confirmar exclusão
                </div>
                <div class="card-body p-4">
                    <p class="mb-3">Tem certeza que deseja excluir o livro abaixo?</p>

                    <table class="table table-bordered">
                        <tr>
                            <th>Título</th>
                            <td><strong>@Model.Titulo</strong></td>
                        </tr>
                        <tr>
                            <th>Autor</th>
                            <td>@Model.Autor</td>
                        </tr>
                        <tr>
                            <th>Categoria</th>
                            <td>@Model.Categoria</td>
                        </tr>
                        <tr>
                            <th>Ano</th>
                            <td>@Model.AnoPublicacao</td>
                        </tr>
                        <tr>
                            <th>Status</th>
                            <td>
                                @if (Model.Disponivel)
                                {
                                    <span class="badge bg-success">Disponível</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Emprestado</span>
                                }
                            </td>
                        </tr>
                    </table>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="bi bi-trash me-2"></i>Confirmar Exclusão
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>