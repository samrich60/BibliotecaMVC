<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Biblioteca Municipal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-book-half me-2 text-warning"></i>Biblioteca Municipal
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house me-1"></i>Início
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Sobre">
                            <i class="bi bi-info-circle me-1"></i>Sobre
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Acervo">
                            <i class="bi bi-journals me-1"></i>Acervo
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Contato">
                            <i class="bi bi-envelope me-1"></i>Contato
                        </a>
                    </li>
                    <li class="nav-item ms-lg-3 mt-2 mt-lg-0">
                        <a class="btn btn-warning btn-sm fw-semibold" asp-controller="Admin" asp-action="Login">
                            <i class="bi bi-lock me-1"></i>Admin
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="mt-5 py-5" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); border-top: 3px solid #ffc107;">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="fw-bold mb-3" style="color: #ffc107;">
                        <i class="bi bi-book-half me-2"></i>Biblioteca Municipal
                    </h5>
                    <p class="small" style="color: #adb5bd;">
                        Um espaço dedicado ao conhecimento, cultura e aprendizado para toda a comunidade.
                    </p>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-bold mb-3" style="color: #ffffff;">Links Rápidos</h6>
                    <ul class="list-unstyled">
                        <li class="mb-1">
                            <a asp-controller="Home" asp-action="Index" class="text-decoration-none small" style="color: #adb5bd;">
                                <i class="bi bi-chevron-right me-1"></i>Início
                            </a>
                        </li>
                        <li class="mb-1">
                            <a asp-controller="Home" asp-action="Sobre" class="text-decoration-none small" style="color: #adb5bd;">
                                <i class="bi bi-chevron-right me-1"></i>Sobre
                            </a>
                        </li>
                        <li class="mb-1">
                            <a asp-controller="Home" asp-action="Acervo" class="text-decoration-none small" style="color: #adb5bd;">
                                <i class="bi bi-chevron-right me-1"></i>Acervo
                            </a>
                        </li>
                        <li class="mb-1">
                            <a asp-controller="Home" asp-action="Contato" class="text-decoration-none small" style="color: #adb5bd;">
                                <i class="bi bi-chevron-right me-1"></i>Contato
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-bold mb-3" style="color: #ffffff;">Contato</h6>
                    <p class="small mb-1" style="color: #adb5bd;">
                        <i class="bi bi-geo-alt me-2" style="color: #ffc107;"></i>Rua Getulio Vargas, 240 — Centro de Cidade Ocidental
                    </p>
                    <p class="small mb-1" style="color: #adb5bd;">
                        <i class="bi bi-telephone me-2" style="color: #ffc107;"></i>(61) 98765-1234
                    </p>
                    <p class="small mb-1" style="color: #adb5bd;">
                        <i class="bi bi-envelope me-2" style="color: #ffc107;"></i>contato@bibliotecamunicipal.com.br
                    </p>
                    <p class="small" style="color: #adb5bd;">
                        <i class="bi bi-clock me-2" style="color: #ffc107;"></i>Seg-Sex: 08h às 18h
                    </p>
                </div>
            </div>
            <hr style="border-color: #444;" class="mt-4" />
            <p class="text-center small mb-0" style="color: #adb5bd;">
                &copy; @DateTime.Now.Year — Biblioteca Municipal. Todos os direitos reservados.
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>